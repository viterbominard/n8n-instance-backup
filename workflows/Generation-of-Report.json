    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================================\n// DETERMINE QUARTER, MONTH, AND TARGET Q SHEET\n// Runs once per new row (runOnceForEachItem)\n// ============================================================\n\nconst row = $input.item.json;\n\n// Parse the date\nconst rawDate = row['Date'];\nlet d = new Date(rawDate);\n\n// Fallback: try MM/DD/YYYY format\nif (isNaN(d.getTime())) {\n  const p = String(rawDate).split('/');\n  if (p.length === 3) {\n    d = new Date(`${p[2]}-${p[0].padStart(2,'0')}-${p[1].padStart(2,'0')}`);\n  }\n}\nif (isNaN(d.getTime())) {\n  throw new Error(`Cannot parse date: ${rawDate}`);\n}\n\nconst month = d.getMonth();   // 0 = Jan … 11 = Dec\nconst year  = d.getFullYear();\n\n// Quarter → sheet name\nlet quarter, qSheet;\nif      (month <= 2)  { quarter = 'Q1'; qSheet = 'Q1 Report'; }\nelse if (month <= 5)  { quarter = 'Q2'; qSheet = 'Q2 Report'; }\nelse if (month <= 8)  { quarter = 'Q3'; qSheet = 'Q3 Report'; }\nelse                  { quarter = 'Q4'; qSheet = 'Q4 Report'; }\n\nconst MONTHS = ['January','February','March','April','May','June',\n                'July','August','September','October','November','December'];\n\n// Standard date string MM/DD/YYYY\nconst dateStr =\n  `${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}/${year}`;\n\nreturn {\n  json: {\n    // Pass all original columns through\n    Date:                row['Date']               || '',\n    Type:                row['Type']               || '',\n    Item:                row['Item']               || '',\n    Quantity:            row['Quantity']            || '',\n    Unit:                row['Unit']               || '',\n    Price:               row['Price']              || '',\n    'Amount Paid':       row['Amount Paid']        || '',\n    Payor:               row['Payor']              || '',\n    'Mode of Payment':   row['Mode of Payment']    || '',\n    'OR Number':         row['OR Number/\\nBilling No.'] || row['OR Number'] || '',\n    'Date Issued':       row['Date Issued']        || '',\n    'Issued by':         row['Issued by']          || '',\n    Source:              row['Source']             || '',\n\n    // Routing metadata\n    _quarter:    quarter,\n    _qSheet:     qSheet,\n    _month:      MONTHS[month],\n    _year:       year,\n    _dateStr:    dateStr\n  }\n};"
      },
